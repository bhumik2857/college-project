<!DOCTYPE html>
<html>
<head>
  <title>Faculty Dashboard</title>
  <link rel="stylesheet" href="/style.css">
</head>

<body>

<div class="dashboard-container">

  <!-- TOP BAR (ONLY ONCE) -->
  <div class="top-bar">
    <a href="/user/logout" class="logout-btn">Logout</a>
  </div>

  <h1>Faculty Dashboard 👩‍🏫</h1>

  <!-- ================= STUDENTS ================= -->
  <h2>Students</h2>

  <% if (!students || students.length === 0) { %>
    <p>No students found</p>
  <% } else { %>

    <% students.forEach(s => { %>

      <div class="card">

        <p><strong>Name:</strong> <%= s.name %></p>
        <p><strong>Email:</strong> <%= s.email %></p>

        <!-- ================= CGPA ================= -->
        <form method="POST" action="/faculty/update-cgpa">
          <input type="hidden" name="studentId" value="<%= s._id %>">

          <label>CGPA:</label>
          <input type="number" step="0.1" name="cgpa" value="<%= s.cgpa %>">

          <button type="submit" class="btn">Update CGPA</button>
        </form>

        <br>

        <!-- ================= ATTENDANCE ================= -->
        <form method="POST" action="/faculty/update-attendance">

          <input type="hidden" name="studentId" value="<%= s._id %>">

          <label>Subject:</label>
          <input name="subject" placeholder="DBMS" required>

          <label>Attended:</label>
          <input type="number" name="attendedClasses" required>

          <label>Total:</label>
          <input type="number" name="totalClasses" required>

          <button type="submit" class="btn">Update Attendance</button>

        </form>

      </div>

    <% }) %>

  <% } %>

  <hr>

  <!-- ================= TIMETABLE ================= -->
  <h2>Add Timetable</h2>

  <form method="POST" action="/faculty/add-timetable">

    <label>Day:</label>
    <input name="day" placeholder="Monday" required>

    <label>Subject:</label>
    <input name="subject" placeholder="DBMS" required>

    <label>Time:</label>
    <input name="time" placeholder="10:00 - 11:00" required>

    <button type="submit" class="btn">Add Timetable</button>

  </form>

  <hr>

  <h2>Weekly Timetable</h2>

  <% if (!timetable || timetable.length === 0) { %>
    <p>No timetable available</p>
  <% } else { %>

    <% timetable.forEach(t => { %>
      <p>
        <%= t.day %> → <%= t.subject %> → <%= t.time %>
      </p>
    <% }) %>

  <% } %>

</div>

</body>
</html>
