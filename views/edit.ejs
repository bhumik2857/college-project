<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Student</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <nav class="navbar">
        <div class="container">
            <h1 class="logo">📚 Student Management</h1>
            <a href="/" class="btn btn-secondary">← Back to Home</a>
        </div>
    </nav>

    <div class="container">
        <div class="form-wrapper">
            <h2>Edit Student</h2>

            <form method="POST" action="/student/edit/<%= student._id %>?_method=PATCH">
                <div class="form-group">
                    <label for="firstName">First Name *</label>
                    <input type="text" id="firstName" name="firstName" value="<%= student.firstName %>" required>
                </div>

                <div class="form-group">
                    <label for="lastName">Last Name *</label>
                    <input type="text" id="lastName" name="lastName" value="<%= student.lastName %>" required>
                </div>

                <div class="form-group">
                    <label for="email">Email *</label>
                    <input type="email" id="email" name="email" value="<%= student.email %>" required>
                </div>

                <div class="form-group">
                    <label for="college">College *</label>
                    <input type="text" id="college" name="college" value="<%= student.college %>" required>
                </div>

                <div class="form-group">
                    <label for="universityRollNo">Roll No *</label>
                    <input type="number" id="universityRollNo" name="universityRollNo" value="<%= student.universityRollNo %>" required>
                </div>

                <div class="form-group">
                    <label for="course">Course *</label>
                    <select id="course" name="course" required>
                        <option <%= student.course === 'B.Tech' ? 'selected' : '' %>>B.Tech</option>
                        <option <%= student.course === 'B.Sc' ? 'selected' : '' %>>B.Sc</option>
                        <option <%= student.course === 'B.A' ? 'selected' : '' %>>B.A</option>
                        <option <%= student.course === 'B.Com' ? 'selected' : '' %>>B.Com</option>
                        <option <%= student.course === 'MBA' ? 'selected' : '' %>>MBA</option>
                        <option <%= student.course === 'MCA' ? 'selected' : '' %>>MCA</option>
                    </select>
                </div>

                <button type="submit" class="btn btn-primary">Update Student</button>
                <a href="/" class="btn btn-secondary">Cancel</a>
            </form>
        </div>
    </div>
</body>
</html>