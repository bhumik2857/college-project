<!DOCTYPE html>
<html>
<head>
    <title>Student Dashboard</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>

<div class="dashboard-container">

    <h1 class="welcome-text">Welcome <%= student.firstName %> 🎓</h1>

    <div class="dashboard-grid">

        <!-- Profile -->
        <div class="dashboard-card">
            <h2>👤 Profile</h2>
            <p><strong>Name:</strong> <%= student.firstName %> <%= student.lastName %></p>
            <p><strong>Roll No:</strong> <%= student.universityRollNo %></p>
            <p><strong>Course:</strong> <%= student.course %></p>
        </div>

        <!-- Attendance -->
        <div class="dashboard-card">
            <h2>📊 Attendance</h2>
            <p>Present: <%= attendance ? attendance.present : 0 %></p>
            <p>Total: <%= attendance ? attendance.total : 0 %></p>
            <p><strong><%= percentage %>%</strong></p>

            <div class="progress-bar-bg">
                <div class="progress-bar-fill" style="width:<%= percentage %>%"></div>
            </div>
        </div>

        <!-- Academics -->
        <div class="dashboard-card">
            <h2>📚 Academics</h2>
            <p><strong>CGPA:</strong> <%= student.cgpa %></p>
            <p><strong>Timetable:</strong></p>
            <p class="timetable"><%= student.timetable %></p>
        </div>

    </div>

</div>

</body>
</html>